class Solution {
    public int subarraySum(int[] nums, int k) {
        
        int totalSubarraysFound = 0;
        int runningSum = 0;
        
        Map<Integer, Integer> timesEachSumWasSeen = new HashMap<>();
        timesEachSumWasSeen.put(0, 1); // base case: prefix sum of 0 seen once
        
        for (int num : nums) {
            runningSum += num;                                                              // step 1: update running sum
            
            int sumWeNeedToHaveSeenBefore = runningSum - k;                                // step 2: what are we looking for?
            int howManyTimesWeFoundIt = timesEachSumWasSeen.getOrDefault(sumWeNeedToHaveSeenBefore, 0);  // step 3: how many times did we see it?
            totalSubarraysFound += howManyTimesWeFoundIt;                                  // step 4: add to total
            
            int howManyTimesThisSumSeenSoFar = timesEachSumWasSeen.getOrDefault(runningSum, 0);  // step 5: get current freq
            int updatedFrequency = howManyTimesThisSumSeenSoFar + 1;                             // step 6: add 1
            timesEachSumWasSeen.put(runningSum, updatedFrequency);                               // step 7: store it back
        }
        
        return totalSubarraysFound;
    }
}


