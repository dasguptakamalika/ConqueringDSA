For binary search, an even easier mental model is:

log₂(n) = "How many times can I divide n by 2 before I reach 1?"
class Solution {
    public int search(int[] nums, int target) {
        for (int i = 0; i < nums.length; i++) {
            if (nums[i] == target) {
                return i;
            }
        }

        return -1;
    }
}
