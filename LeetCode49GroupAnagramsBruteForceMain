import java.util.*;

// Main class to run the program
class Main {

    public static void main(String[] args) {

        // Input array of strings
        String[] strs = {"eat", "tea", "tan", "ate", "nat", "bat"};

        // Creating object of Solution class
        Solution sol = new Solution();

        // Calling the function and printing result
        System.out.println(sol.groupAnagrams(strs));
    }
}

class Solution {

    // Function to group anagrams
    public List<List<String>> groupAnagrams(String[] strs) {

        // Final answer list
        // This will store all groups
        List<List<String>> result = new ArrayList<>();

        // Boolean array to track already grouped words
        // Initially all are false
        boolean[] used = new boolean[strs.length];

        // Outer loop picks one word at a time
        for (int i = 0; i < strs.length; i++) {

            // If word already grouped earlier,
            // skip this iteration
            if (used[i]) {
                continue;
            }

            // Create a new group for current word
            List<String> group = new ArrayList<>();

            // Add current word into group
            group.add(strs[i]);

            // Mark current word as used
            used[i] = true;

            // Inner loop checks remaining words
            // to find matching anagrams
            for (int j = i + 1; j < strs.length; j++) {

                // Condition:
                // 1. word should NOT already be used
                // 2. word should be an anagram

                if (!used[j] && isAnagram(strs[i], strs[j])) {

                    // Add matching anagram to group
                    group.add(strs[j]);

                    // Mark it as used
                    used[j] = true;
                }
            }

            // Finished one full anagram group
            // Add it into final result
            result.add(group);
        }

        // Return final grouped answer
        return result;
    }

    // Helper function to check if two strings are anagrams
    private boolean isAnagram(String a, String b) {

        // Convert both strings into character arrays
        char[] arr1 = a.toCharArray();
        char[] arr2 = b.toCharArray();

        // Sort both arrays
        Arrays.sort(arr1);
        Arrays.sort(arr2);

        // If sorted arrays are same,
        // then strings are anagrams
        return Arrays.equals(arr1, arr2);
    }
}
